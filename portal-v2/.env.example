# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# API base URL (Express backend)
# In development, Vite proxies /api to localhost:3000, so leave this blank.
# In production on Vercel, set this to your deployed Express backend URL (e.g. https://your-backend.railway.app)
VITE_API_BASE_URL=

# GitHub (used by Express backend, not Vite)
GITHUB_TOKEN=ghp_your_token
GITHUB_OWNER=JFlo21
GITHUB_REPO=Generate-Weekly-PDFs-DSR-Resiliency

# Express backend
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development

# Sentry Error Monitoring (optional)
VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=   # Defaults to Vite MODE
# VITE_SENTRY_RELEASE=       # Set by CI/hosting provider
