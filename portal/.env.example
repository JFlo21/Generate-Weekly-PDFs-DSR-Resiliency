# Portal Configuration
PORT=3000
NODE_ENV=production

# Session secret (generate a strong random string)
SESSION_SECRET=change-this-to-a-strong-random-string

# GitHub API configuration
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=JFlo21
GITHUB_REPO=Generate-Weekly-PDFs-DSR-Resiliency

# Default admin credentials
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$your_bcrypt_hash_here

# Proxy / hosting
# Set to 'true' when deployed behind a reverse proxy (Railway, Render, Heroku, etc.)
# Required for express-rate-limit to read the correct client IP from X-Forwarded-For
TRUST_PROXY=true

# CORS allowed origins (frontend URLs that may call this backend)
CORS_ORIGIN=https://your-portal-v2.vercel.app
# CORS_ORIGIN_2=https://optional-second-origin.example.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
