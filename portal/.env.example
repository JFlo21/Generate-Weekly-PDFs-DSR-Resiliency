# Portal Configuration
PORT=3000
NODE_ENV=production

# Session secret (generate a strong random string)
SESSION_SECRET=change-this-to-a-strong-random-string
# Set to true only when using the legacy /auth session login flow for /api/*
API_AUTH_REQUIRED=false

# GitHub API configuration
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=JFlo21
GITHUB_REPO=Generate-Weekly-PDFs-DSR-Resiliency

# Default admin credentials
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$your_bcrypt_hash_here

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (Render backend consumed by Vercel frontend)
# Support a single origin or a comma-separated list for preview/prod domains.
CORS_ORIGIN=https://your-vercel-app.vercel.app
# CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-team-git-feature.vercel.app

# Sentry Error Monitoring (optional)
PORTAL_SENTRY_DSN=
# SENTRY_RELEASE=      # Set by hosting provider or CI
# SENTRY_ENVIRONMENT=   # Defaults to NODE_ENV
